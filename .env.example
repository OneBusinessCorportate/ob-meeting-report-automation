SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TIMELESS_API_TOKEN=
TIMELESS_API_BASE_URL=https://api.timeless.day/v1
# Optional Timeless tuning (override only if the real API differs from defaults;
# run `python scripts/check_timeless.py` to discover the correct shapes):
#   Auth header style: bearer (default) | x-api-key | token
# TIMELESS_AUTH_SCHEME=bearer
#   Listing endpoint path (relative to base url):
# TIMELESS_MEETINGS_PATH=meetings
#   Comma-separated transcript path templates ("{id}" is substituted):
# TIMELESS_TRANSCRIPT_PATH_TEMPLATES=meetings/{id}/transcript,meetings/{id}/transcript/full,transcripts/{id}
#   Date-range query param names (override if the API ignores start_date/end_date;
#   `python scripts/debug_timeless_api.py` discovers the right ones, e.g. from/to):
# TIMELESS_START_PARAM=start_date
# TIMELESS_END_PARAM=end_date
#   Status filter value. Set empty (TIMELESS_STATUS_FILTER=) to omit it entirely
#   if the listing returns 200 but 0 meetings because of the status filter:
# TIMELESS_STATUS_FILTER=completed
#   Retries for transient (network / 429 / 5xx) errors:
# TIMELESS_MAX_RETRIES=3

# AI provider: "anthropic" (default) or "gemini".
AI_PROVIDER=anthropic
# Required when AI_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
# Required when AI_PROVIDER=gemini:
GEMINI_API_KEY=
# Optional. Defaults per provider: claude-sonnet-4-20250514 / gemini-2.5-pro.
AI_MODEL_ID=claude-sonnet-4-20250514
AI_PROMPT_VERSION=full_transcript_prompt_v3_1
# Max output tokens for the L2 report. Raise if long transcripts produce
# "invalid JSON" (truncated) failures. Default 16384.
AI_MAX_OUTPUT_TOKENS=16384

TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGEMENT_CHAT_ID=

MEETING_DEFAULT_SOURCE=timeless
MEETING_DEFAULT_LANGUAGE=hy
MEETING_DELIVERY_TIME=11:30
# Days back the daily run also retries pending/failed meetings, so failures
# (e.g. AI quota) auto-recover on the next scheduled run. 0 = today only.
MEETING_ANALYZE_LOOKBACK_DAYS=0
# Known accounting-team roster. The report goes through EVERY accountant by name
# and flags anyone who said nothing as "не принимал(а) участия". Comma-separated
# "Имя:роль" (role optional). If left empty, the roster is loaded automatically
# from the internal participants in the mtg_participants table — set this only to
# override the DB roster.
# MEETING_TEAM_ROSTER=Эмилия Аванесян:руководитель,Стелла Бухгалтер:бухгалтер,Наира Мхитарян:бухгалтер,Аваг Бухгалтер:бухгалтер,Лилит Бухгалтер:бухгалтер,Оля Бухгалтер:бухгалтер,Артак Бухгалтер:бухгалтер,Тагуи Бухгалтер:бухгалтер,Гор Менеджер:менеджер

# --- Telegram delivery reliability ---
# Retries (with exponential backoff 2s,4s,8s,16s...) when Telegram times out or
# returns a transient error (429/5xx), so a report is not lost on one timeout.
TELEGRAM_MAX_RETRIES=4
# Per-request timeout in seconds for the Telegram Bot API call.
TELEGRAM_REQUEST_TIMEOUT=30

# --- Task II: interview / onboarding call transcription (transcript-only) ---
INTERVIEW_CALLS_TABLE=interview_calls
# Optional: Supabase table holding interview links (leave empty to use --csv/--url)
INTERVIEW_LINKS_TABLE=
INTERVIEW_DEFAULT_ROLE=бухгалтер

# --- «Обучающий центр / анализ собеседований» (full analysis pipeline) ---
# Where the candidate/interview table is read from. Leave INTERVIEW_SHEET_SOURCE
# empty to auto-detect: google_api > csv_url > local_xlsx.
# INTERVIEW_SHEET_SOURCE=google_api
# Google Sheets spreadsheet id (the part between /d/ and /edit in the URL):
INTERVIEW_SPREADSHEET_ID=
# Comma-separated tab names to read (the «Бух» tab holds the interview links):
INTERVIEW_SHEET_TABS=Бух
# Alternative to the API: a published-to-web CSV export URL of one tab:
INTERVIEW_SHEET_CSV_URL=
# Alternative: path to a local .xlsx export of the sheet:
INTERVIEW_LOCAL_XLSX=
# Google service account for Sheets API + Google-Doc transcript export. Provide
# EITHER the inline JSON blob OR a path to the key file (never commit the key):
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Output toggles for the analysis pipeline:
INTERVIEW_ANALYSIS_ENABLED=true
INTERVIEW_TELEGRAM_ENABLED=false
INTERVIEW_SHEET_WRITEBACK_ENABLED=false
# Optional dedicated Telegram chat for interview reports (else the mgmt chat):
INTERVIEW_TELEGRAM_CHAT_ID=
INTERVIEW_ANALYSIS_PROMPT_VERSION=interview_analysis_v1
